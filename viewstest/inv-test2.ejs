<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Invoice <%= invoiceNumber %></title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    color: #2d2d2d;
    font-size: 13px;
    padding: 40px;
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 3px solid #1f2937;
    padding-bottom: 20px;
    margin-bottom: 30px;
  }
  .company h1 { font-size: 20px; color: #246bce; text-transform: uppercase;}
  .company p { color: #555; line-height: 1.5; margin-top: 4px; }
  .invoice-title { text-align: right; }
  .invoice-title h2 {
    font-size: 28px;
    color: #1f2937;
    letter-spacing: 1px;
  }
  .invoice-title p { margin-top: 6px; color: #555; }
  .meta-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 30px;
  }
  .meta-block h3 {
    font-size: 11px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 6px;
    letter-spacing: 0.5px;
  }
  .meta-block p { line-height: 1.5; }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 30px;
  }
  thead th {
    background: #1f2937;
    color: #fff;
    text-align: left;
    padding: 10px 12px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  thead th.num, tbody td.num { text-align: right; }
  tbody td {
    padding: 10px 12px;
    border-bottom: 1px solid #e5e7eb;
  }
  tbody tr:nth-child(even) { background: #f9fafb; }
  .totals {
    width: 280px;
    margin-left: auto;
    margin-bottom: 30px;
  }
  .totals div {
    display: flex;
    justify-content: space-between;
    padding: 6px 12px;
  }
  .totals .grand-total {
    border-top: 2px solid #1f2937;
    font-weight: bold;
    font-size: 15px;
    margin-top: 6px;
  }
  .notes {
    border-top: 1px solid #e5e7eb;
    padding-top: 16px;
    color: #555;
    line-height: 1.6;
  }
  .footer {
    margin-top: 40px;
    text-align: center;
    color: #999;
    font-size: 11px;
  }
  .status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 11px;
    text-transform: uppercase;
    font-weight: bold;
    margin-top: 8px;
  }
  .status.paid { background: #dcfce7; color: #166534; }
  .status.unpaid { background: #fee2e2; color: #991b1b; }
  .status.pending { background: #fef9c3; color: #854d0e; }
</style>
</head>
<body>

  <div class="header">
    <div class="company">
      <h1><%= company.name %></h1>
      <p>
        <%= company.address %><br>
        <%= company.city %><br>
        <% if (company.email) { %>Email: <%= company.email %><br><% } %>
        <% if (company.phone) { %>Phone: <%= company.phone %><% } %>
      </p>
    </div>
    <div class="invoice-title">
      <h2>INVOICE</h2>
      <p>#<%= invoiceNumber %></p>
      <span class="status <%= status.toLowerCase() %>"><%= status %></span>
    </div>
  </div>

  <div class="meta-row">
    <div class="meta-block">
      <h3>Bill To</h3>
      <p>
        <strong><%= client.name %></strong><br>
        <%= client.address %><br>
        <%= client.city %><br>
        <% if (client.email) { %><%= client.email %><% } %>
      </p>
    </div>
    <div class="meta-block">
      <h3>Invoice Details</h3>
      <p>
        Issue Date: <%= issueDate %><br>
        Due Date: <%= dueDate %><br>
        <% if (poNumber) { %>PO Number: <%= poNumber %><% } %>
      </p>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th class="num">Qty</th>
        <th class="num">Unit Price</th>
        <th class="num">Amount</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="num"><%= item.quantity %></td>
          <td class="num"><%= currency %><%= item.unitPrice.toFixed(2) %></td>
          <td class="num"><%= currency %><%= (item.quantity * item.unitPrice).toFixed(2) %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <div class="totals">
    <div>
      <span>Subtotal</span>
      <span><%= currency %><%= subtotal.toFixed(2) %></span>
    </div>
    <% if (typeof taxRate !== 'undefined' && taxRate > 0) { %>
    <div>
      <span>Tax (<%= taxRate %>%)</span>
      <span><%= currency %><%= taxAmount.toFixed(2) %></span>
    </div>
    <% } %>
    <% if (typeof discount !== 'undefined' && discount > 0) { %>
    <div>
      <span>Discount</span>
      <span>-<%= currency %><%= discount.toFixed(2) %></span>
    </div>
    <% } %>
    <div class="grand-total">
      <span>Total Due</span>
      <span><%= currency %><%= total.toFixed(2) %></span>
    </div>
  </div>

  <% if (notes) { %>
  <div class="notes">
    <strong>Notes:</strong> <%= notes %>
  </div>
  <% } %>

  <% if (bankDetails) { %>
  <div class="notes">
    <strong>Payment Details:</strong> <%= bankDetails %>
  </div>
  <% } %>

  <div class="footer">
    Thank you for your business — <%= company.name %>
  </div>

</body>
</html>
