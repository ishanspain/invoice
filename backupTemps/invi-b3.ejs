<%
  const value = (input, fallback = "") =>
    input !== undefined && input !== null && input !== "" ? input : fallback;

  const currencySymbol = value(typeof currency !== "undefined" ? currency : undefined, "₹");
  const invoiceId = value(typeof invoiceNumber !== "undefined" ? invoiceNumber : undefined);
  const invoiceDate = value(typeof issueDate !== "undefined" ? issueDate : undefined, value(typeof date !== "undefined" ? date : undefined));
  const orderNumberText = value(typeof orderNumber !== "undefined" ? orderNumber : undefined, value(typeof orderId !== "undefined" ? orderId : undefined, value(invoiceId, "PC1207260001")));
  const orderPlacedDate = value(typeof orderDate !== "undefined" ? orderDate : undefined, value(typeof placedAt !== "undefined" ? placedAt : undefined, value(invoiceDate, "12/7/2026")));
  const payment = typeof paymentInfo !== "undefined" ? paymentInfo : {};
  const sellerData = typeof sellerInfo !== "undefined"
    ? sellerInfo
    : (typeof seller !== "undefined" ? seller : (typeof company !== "undefined" ? company : {}));
  const customerData = typeof customerInfo !== "undefined"
    ? customerInfo
    : (typeof customer !== "undefined" ? customer : (typeof client !== "undefined" ? client : {}));
  const shippingData = typeof shippingInfo !== "undefined"
    ? shippingInfo
    : (typeof shipping !== "undefined"
      ? shipping
      : (typeof shippingAddress !== "undefined" ? shippingAddress : customerData));
  const rows = Array.isArray(typeof items !== "undefined" ? items : undefined) ? items : [];
  const totalsData = typeof totals !== "undefined" ? totals : {};

  const money = (input) => {
    const number = Number(input);
    return Number.isFinite(number) ? `${currencySymbol}${number.toFixed(2)}` : `${currencySymbol}${value(input, "0.00")}`;
  };
  const amount = (input) => {
    const number = Number(input);
    return Number.isFinite(number) ? `${currencySymbol}${number.toFixed(2)}` : `${currencySymbol}${value(input, "0.00")}`;
  };
  const numberWordsUnderThousand = (input) => {
    const ones = ["", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine", "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen", "Seventeen", "Eighteen", "Nineteen"];
    const tens = ["", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety"];
    let number = input;
    let words = "";

    if (number >= 100) {
      words += `${ones[Math.floor(number / 100)]} Hundred`;
      number %= 100;
      if (number) words += " ";
    }

    if (number >= 20) {
      words += tens[Math.floor(number / 10)];
      number %= 10;
      if (number) words += ` ${ones[number]}`;
    } else if (number > 0) {
      words += ones[number];
    }

    return words;
  };
  const numberToWords = (input) => {
    let number = Math.floor(Math.abs(Number(input)));
    if (!Number.isFinite(number) || number === 0) return "Zero";

    const parts = [];
    const groups = [
      { value: 10000000, label: "Crore" },
      { value: 100000, label: "Lakh" },
      { value: 1000, label: "Thousand" },
      { value: 1, label: "" },
    ];

    groups.forEach((group) => {
      const count = Math.floor(number / group.value);
      if (count) {
        parts.push(`${numberWordsUnderThousand(count)}${group.label ? ` ${group.label}` : ""}`);
        number %= group.value;
      }
    });

    return parts.join(" ");
  };
  const rupeesInWords = (input) => {
    const number = Number(input);
    if (!Number.isFinite(number)) return "";

    const rupees = Math.floor(Math.abs(number));
    const paise = Math.round((Math.abs(number) - rupees) * 100);
    const paiseText = paise ? ` and ${numberToWords(paise)} Paise` : "";
    return `Rupees ${numberToWords(rupees)}${paiseText} Only`;
  };
  const currencyLabel = currencySymbol.trim();

  const lineUnit = (item) => value(item.unitPrice, value(item.unit, 0));
  const lineQty = (item) => Number(value(item.quantity, item.qty || 0));
  const lineDiscount = (item) => value(item.discount, value(item.discountAmount, value(item.discountValue, 0)));
  const lineTax = (item) => value(item.tax, value(item.gst, 0));
  const lineTotal = (item) => value(item.total, value(item.amount, Number(lineUnit(item)) * lineQty(item)));
  const numeric = (input) => {
    const number = Number(input);
    return Number.isFinite(number) ? number : 0;
  };
  const sumRows = (mapper) => rows.reduce((sum, item) => sum + numeric(mapper(item)), 0);
  const labelValue = (label, input) => `${label}: ${input}`;
  const addonText = (addon) => {
    if (typeof addon === "string") return addon;
    if (!addon || typeof addon !== "object") return "";

    const name = value(addon.name, value(addon.title, value(addon.label, "")));
    const price = value(addon.price, value(addon.amount, value(addon.value, "")));
    return price !== "" ? `${name} (+${money(price)})` : name;
  };
  const detailText = (detail) => {
    if (typeof detail === "string") return detail;
    if (!detail || typeof detail !== "object") return "";

    const label = value(detail.label, value(detail.name, value(detail.key, "")));
    const detailValue = value(detail.value, value(detail.text, value(detail.description, "")));
    return label && detailValue ? labelValue(label, detailValue) : value(detailValue, label);
  };
  const pushList = (target, label, input) => {
    if (!input) return;

    if (Array.isArray(input)) {
      const list = input.map(label === "Addons" ? addonText : detailText).filter(Boolean);
      if (list.length) target.push(labelValue(label, list.join(", ")));
      return;
    }

    target.push(labelValue(label, input));
  };
  const lineDetails = (item) => {
    const details = [];
    pushList(details, "Service", value(item.service, item.serviceName));
    pushList(details, "Size", value(item.size, item.paperSize));
    pushList(details, "Color", item.color);
    pushList(details, "Print Type", value(item.printType, item.side));
    pushList(details, "Addons", value(item.addons, value(item.addOns, item.options)));

    const extraDetails = value(item.details, value(item.orderDetails, item.metadata));
    if (Array.isArray(extraDetails)) {
      extraDetails.map(detailText).filter(Boolean).forEach((detail) => details.push(detail));
    } else if (extraDetails && typeof extraDetails === "object") {
      Object.entries(extraDetails).forEach(([key, detailValue]) => {
        if (detailValue !== undefined && detailValue !== null && detailValue !== "") {
          details.push(labelValue(key, detailValue));
        }
      });
    }

    return details;
  };

  const itemSubtotal = value(totalsData.itemSubtotal, value(typeof subtotal !== "undefined" ? subtotal : undefined, 0));
  const invoiceAddonsSubtotal = value(totalsData.addonsSubtotal, typeof addonsSubtotal !== "undefined" ? addonsSubtotal : 0);
  const invoiceDeliveryFee = value(totalsData.deliveryFee, typeof deliveryFee !== "undefined" ? deliveryFee : 0);
  const invoicePlatformFee = value(totalsData.platformFee, typeof platformFee !== "undefined" ? platformFee : 0);
  const invoiceDiscount = value(totalsData.discount, value(totalsData.discountAmount, typeof discount !== "undefined" ? discount : 0));
  const invoiceTaxAmount = value(totalsData.taxAmount, typeof taxAmount !== "undefined" ? taxAmount : 0);
  const grandTotal = value(totalsData.grandTotal, value(typeof total !== "undefined" ? total : undefined, 0));
  const totalUnitAmount = value(itemSubtotal, sumRows((item) => numeric(lineUnit(item)) * lineQty(item)));
  const totalQuantity = value(totalsData.quantity, value(totalsData.qty, sumRows(lineQty)));
  const totalDiscountAmount = value(invoiceDiscount, sumRows(lineDiscount));
  const totalTaxValue = value(invoiceTaxAmount, sumRows(lineTax));
  const totalPayableAmount = value(grandTotal, sumRows(lineTotal));
  const paymentModeText = value(payment.mode, value(typeof paymentMode !== "undefined" ? paymentMode : undefined, ""));
  const brandName = value(sellerData.brandName, value(sellerData.name, "PrintCampus"));
  const brandLogoSrc = value(sellerData.logoDataUri, value(typeof logoDataUri !== "undefined" ? logoDataUri : undefined, ""));
  const qrCodeSrc = value(typeof qrCodeDataUrl !== "undefined" ? qrCodeDataUrl : undefined, value(typeof qrCodeDataUri !== "undefined" ? qrCodeDataUri : undefined, ""));
  const signatureSrc = value(typeof signatureDataUri !== "undefined" ? signatureDataUri : undefined, value(sellerData.signatureDataUri, ""));
  const sellerWebsite = value(sellerData.website, "www.printcampus.in");
  const sellerWebsiteHref = /^https?:\/\//i.test(sellerWebsite) ? sellerWebsite : `https://${sellerWebsite}`;
%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Invoice <%= invoiceId %></title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: Arial, Helvetica, sans-serif;
    color: #1f2937;
    font-size: 12px;
    padding: 44px 50px;
    background: #ffffff;
  }
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 22px;
    border-bottom: 1px solid #e2e8f0;
  }
  .brand {
    width: 170px;
  }
  .brand-logo {
    display: block;
    width: 150px;
    height: 150px;
    object-fit: contain;
  }
  .brand p, .invoice-meta p, .party p, .payment p {
    color: #475569;
    line-height: 1.45;
  }
  .invoice-meta {
    text-align: right;
    min-width: 230px;
  }
  .invoice-meta h2 {
    color: #0f172a;
    font-size: 18px;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  .section-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 36px;
    row-gap: 20px;
    margin-top: 28px;
  }
  .section-title {
    color: #0f172a;
    font-size: 13px;
    font-weight: 800;
    margin-bottom: 9px;
  }
  .party strong {
    display: block;
    color: #334155;
    margin-bottom: 4px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 28px;
    table-layout: fixed;
  }
  thead th {
    background: #f8fafc;
    color: #1e293b;
    border-bottom: 1px solid #e2e8f0;
    font-size: 11px;
    padding: 10px 8px;
    text-align: left;
  }
  tbody td {
    border-bottom: 1px solid #e2e8f0;
    color: #334155;
    padding: 12px 8px;
    vertical-align: top;
    page-break-inside: avoid;
  }
  .serial { width: 6%; }
  .description { width: 34%; }
  .number { text-align: right; }
  .item-name {
    color: #334155;
    font-weight: 700;
    margin-bottom: 4px;
    overflow-wrap: anywhere;
  }
  .item-detail {
    color: #64748b;
    font-size: 11px;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .total-row td {
    background: #0f172a;
    border-bottom: 0;
    color: #ffffff;
    font-weight: 700;
    padding: 11px 8px;
  }
  .total-row .payment-mode {
    text-align: left;
  }
  .pricing-summary-row td {
    background: #ffffff;
    border-bottom: 0;
    padding: 12px 8px 6px;
  }
  .pricing-summary {
    margin-left: auto;
    width: 300px;
    color: #334155;
    font-size: 13px;
  }
  .pricing-summary-line {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 2px 0;
  }
  .pricing-summary-total {
    border-top: 1px solid #94a3b8;
    color: #000000;
    font-size: 16px;
    font-weight: 800;
    margin-top: 8px;
    padding-top: 6px;
  }
  .total-words-row td {
    background: #f8fafc;
    color: #0f172a;
    font-weight: 700;
    text-align: right;
  }
  .total-words-label {
    color: #0f172a;
    font-weight: 800;
  }
  .invoice-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    margin-top: 26px;
  }
  .invoice-qr {
    width: 150px;
  }
  .invoice-qr img {
    display: block;
    margin-bottom: 12px;
  }
  .invoice-qr-code {
    width: 130px;
    height: 130px;
    object-fit: contain;
  }
  .invoice-signature {
    width: 130px;
    height: 58px;
    margin-left: auto;
    object-fit: contain;
  }
  .notes {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    border-top: 1px solid #cbd5e1;
    color: #64748b;
    font-size: 11px;
    line-height: 1.5;
    margin-top: 70px;
    padding-top: 12px;
  }
  .footer-contact {
    color: #475569;
    text-align: left;
  }
  .footer-contact-label {
    color: #0f172a;
    font-weight: 800;
  }
  .footer-contact a {
    color: #1d4ed8;
    text-decoration: none;
  }
  .footer-tagline {
    color: #475569;
    text-align: right;
  }
  .page {
    display: block;
    margin-top: 6px;
    text-align: right;
  }
  @media print {
    body { padding: 34px 42px; }
  }
</style>
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <% if (brandLogoSrc) { %>
        <img class="brand-logo" src="<%= brandLogoSrc %>" alt="<%= brandName %>">
      <% } else { %>
        <strong><%= brandName %></strong>
      <% } %>
    </div>
    <div class="invoice-meta">
      <h2>TAX INVOICE</h2>
      <p>
        <strong>Invoice Number:</strong> <%= invoiceId %><br>
        <strong>Invoice Date:</strong> <%= invoiceDate %><br>
        <strong>Order Number:</strong> <%= orderNumberText %><br>
        <strong>Order Date:</strong> <%= orderPlacedDate %>
      </p>
    </div>
  </header>

  <section class="section-grid">
    <div class="party">
      <div class="section-title">Sold By (Seller):</div>
      <p>
        <strong><%= value(sellerData.legalName, value(sellerData.name, "PrintCampus Solutions Private Limited")) %></strong>
        <%= value(sellerData.address, "") %><% if (sellerData.address) { %><br><% } %>
        <%= value(sellerData.city, "") %><% if (sellerData.city) { %><br><% } %>
        <% if (sellerData.gstin) { %>GSTIN: <%= sellerData.gstin %><% } %>
      </p>
    </div>
    <div class="party">
      <div class="section-title">Bill To:</div>
      <p>
        <strong><%= value(customerData.name, "") %></strong>
        <%= value(customerData.address, "") %><% if (customerData.address) { %><br><% } %>
        <%= value(customerData.city, "") %><% if (customerData.city) { %><br><% } %>
        <% if (customerData.phone) { %>Phone: <%= customerData.phone %><br><% } %>
        <% if (customerData.email) { %><%= customerData.email %><% } %>
      </p>
    </div>
    <div class="party">
      <div class="section-title">Shipping Address:</div>
      <p>
        <strong><%= value(shippingData.name, value(customerData.name, "")) %></strong>
        <%= value(shippingData.address, value(customerData.address, "")) %><% if (value(shippingData.address, value(customerData.address, ""))) { %><br><% } %>
        <%= value(shippingData.city, value(customerData.city, "")) %><% if (value(shippingData.city, value(customerData.city, ""))) { %><br><% } %>
        <% if (value(shippingData.phone, customerData.phone)) { %>Phone: <%= value(shippingData.phone, customerData.phone) %><br><% } %>
        <% if (value(shippingData.email, customerData.email)) { %><%= value(shippingData.email, customerData.email) %><% } %>
      </p>
    </div>
  </section>

  <table>
    <thead>
      <tr>
        <th class="serial">S.No</th>
        <th class="description">Item &amp; Description</th>
        <th class="number">Unit Price (<%= currencyLabel %>)</th>
        <th class="number">Qty</th>
        <th class="number">Discount (<%= currencyLabel %>)</th>
        <th class="number">Tax (GST) (<%= currencyLabel %>)</th>
        <th class="number">Total (<%= currencyLabel %>)</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length) { %>
        <% rows.forEach(function(item, index) { %>
          <tr>
            <td><%= value(item.serial, index + 1) %></td>
            <td>
              <div class="item-name"><%= value(item.title, value(item.description, "Item")) %></div>
              <% lineDetails(item).forEach(function(detail) { %>
                <div class="item-detail"><%= detail %></div>
              <% }); %>
            </td>
            <td class="number"><%= amount(lineUnit(item)) %></td>
            <td class="number"><%= lineQty(item) %></td>
            <td class="number"><%= amount(lineDiscount(item)) %></td>
            <td class="number"><%= amount(lineTax(item)) %></td>
            <td class="number"><%= amount(lineTotal(item)) %></td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="7">No invoice items available.</td>
        </tr>
      <% } %>
      <tr class="total-row">
        <td>TOTAL</td>
        <td class="payment-mode"><%= paymentModeText ? `${paymentModeText} (mode of payment)` : "Mode of payment" %></td>
        <td class="number"><%= amount(totalUnitAmount) %></td>
        <td class="number"><%= totalQuantity %></td>
        <td class="number"><%= amount(totalDiscountAmount) %></td>
        <td class="number"><%= amount(totalTaxValue) %></td>
        <td class="number"><%= amount(totalPayableAmount) %></td>
      </tr>
      <tr class="pricing-summary-row">
        <td colspan="7">
          <div class="pricing-summary">
            <div class="pricing-summary-line">
              <span>Item Subtotal:</span>
              <span><%= amount(totalUnitAmount) %></span>
            </div>
            <div class="pricing-summary-line">
              <span>Add-ons Subtotal:</span>
              <span><%= amount(invoiceAddonsSubtotal) %></span>
            </div>
            <div class="pricing-summary-line">
              <span>Delivery Fee:</span>
              <span><%= amount(invoiceDeliveryFee) %></span>
            </div>
            <div class="pricing-summary-line">
              <span>Platform Fee:</span>
              <span><%= amount(invoicePlatformFee) %></span>
            </div>
            <div class="pricing-summary-line">
              <span>Discount Amount:</span>
              <span><%= amount(totalDiscountAmount) %></span>
            </div>
            <div class="pricing-summary-line">
              <span>Tax (18% IGST):</span>
              <span><%= amount(totalTaxValue) %></span>
            </div>
            <div class="pricing-summary-line pricing-summary-total">
              <span>Grand Total:</span>
              <span><%= amount(totalPayableAmount) %></span>
            </div>
          </div>
        </td>
      </tr>
      <tr class="total-words-row">
        <td colspan="7"><span class="total-words-label">Amount in words:</span> <%= rupeesInWords(totalPayableAmount) %></td>
      </tr>
    </tbody>
  </table>

  <section class="invoice-bottom">
    <% if (qrCodeSrc) { %>
      <div class="invoice-qr">
        <img class="invoice-qr-code" src="<%= qrCodeSrc %>" alt="Invoice verification QR code">
      </div>
    <% } %>
    <% if (signatureSrc) { %>
      <img class="invoice-signature" src="<%= signatureSrc %>" alt="Authorized signature">
    <% } %>
  </section>

  <footer class="notes">
    <div class="footer-contact">
      <span class="footer-contact-label">Email:</span> <%= value(sellerData.email, "support@printcampus.in") %><br>
      <span class="footer-contact-label">Phone:</span> <%= value(sellerData.phone, "+91 1122334455") %><br>
      <span class="footer-contact-label">Website:</span> <a href="<%= sellerWebsiteHref %>"><%= sellerWebsite %></a>
    </div>
    <div class="footer-tagline">
      <%= value(sellerData.tagline, "Online Document Printing & Stationery Services") %>
    </div>
  </footer>
</body>
</html>
